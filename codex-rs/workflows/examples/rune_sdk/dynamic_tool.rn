pub async fn run(ctx, input) {
    let echo = ctx.defineTool(#{
        name: "echo_context",
        description: "Echoes a short string back to the agent.",
        inputSchema: #{
            type: "object",
            properties: #{
                text: #{ type: "string" },
            },
            required: ["text"],
        },
    }, async |args, call| {
        #{
            contentItems: [{
                type: "inputText",
                text: args.text,
            }],
            success: true,
            callId: call.callId,
        }
    });

    let agent = ctx.createAgent(#{
        tools: [echo],
    }).await;

    agent.run(input.prompt, #{}).await
}
