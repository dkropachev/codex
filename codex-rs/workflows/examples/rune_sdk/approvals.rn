pub async fn run(ctx, input) {
    ctx.appServer.configure(#{
        connection: "require-existing",
    });

    ctx.appServer.setApprovals(#{
        mode: "handler",
        onApproval: async |approval| {
            ctx.reportToUserMarkdown("Approval requested by `" + approval.method + "`.");
            #{
                decision: "denied",
                reason: "This example declines approval requests by default.",
            }
        },
    });

    let agent = ctx.resumeAgent(input.threadId, #{}).await;
    agent.run(input.prompt, #{}).await
}
