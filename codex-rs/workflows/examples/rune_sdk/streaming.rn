pub async fn run(ctx, input) {
    let agent = ctx.createAgent(#{}).await;
    let stream = agent.runStreamed(input.prompt, #{}).await;
    let events = [];

    loop {
        let event = stream.next().await;
        if event == () {
            break;
        }

        events.push(event);

        if event.method == "item/completed" {
            ctx.status(#{
                workflowName: "Rune stream",
                workflowStatus: "received item",
                threads: [#{ name: "agent", status: event.method }],
            });
        }
    }

    #{ events }
}
