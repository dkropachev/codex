{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "definitions": {
    "WorkflowChildStatus": {
      "properties": {
        "threads": {
          "items": {
            "$ref": "#/definitions/WorkflowThreadStatus"
          },
          "type": "array"
        },
        "workflowName": {
          "type": "string"
        },
        "workflowStatus": {
          "type": "string"
        }
      },
      "required": [
        "threads",
        "workflowName",
        "workflowStatus"
      ],
      "type": "object"
    },
    "WorkflowStatusUpdate": {
      "properties": {
        "childStatuses": {
          "items": {
            "$ref": "#/definitions/WorkflowChildStatus"
          },
          "type": "array"
        },
        "threads": {
          "items": {
            "$ref": "#/definitions/WorkflowThreadStatus"
          },
          "type": "array"
        },
        "workflowName": {
          "type": "string"
        },
        "workflowStatus": {
          "type": "string"
        }
      },
      "required": [
        "childStatuses",
        "threads",
        "workflowName",
        "workflowStatus"
      ],
      "type": "object"
    },
    "WorkflowThreadStatus": {
      "properties": {
        "name": {
          "type": "string"
        },
        "status": {
          "type": "string"
        }
      },
      "required": [
        "name",
        "status"
      ],
      "type": "object"
    }
  },
  "properties": {
    "data": true,
    "message": {
      "type": "string"
    },
    "runId": {
      "type": "string"
    },
    "status": {
      "anyOf": [
        {
          "$ref": "#/definitions/WorkflowStatusUpdate"
        },
        {
          "type": "null"
        }
      ]
    },
    "threadId": {
      "type": [
        "string",
        "null"
      ]
    }
  },
  "required": [
    "message",
    "runId"
  ],
  "title": "WorkflowProgressNotification",
  "type": "object"
}