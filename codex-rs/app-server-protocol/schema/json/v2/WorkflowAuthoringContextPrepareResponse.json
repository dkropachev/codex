{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "definitions": {
    "WorkflowConfigValues": {
      "properties": {
        "commit_policy": {
          "type": "string"
        },
        "default_location": {
          "type": "string"
        },
        "dependency_update_policy": {
          "type": "string"
        },
        "max_repair_cycles": {
          "format": "uint32",
          "minimum": 0.0,
          "type": "integer"
        },
        "repair_mode": {
          "type": "string"
        },
        "search_paths": {
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "validation_profile": {
          "type": "string"
        }
      },
      "required": [
        "commit_policy",
        "default_location",
        "dependency_update_policy",
        "max_repair_cycles",
        "repair_mode",
        "search_paths",
        "validation_profile"
      ],
      "type": "object"
    },
    "WorkflowRootInfo": {
      "properties": {
        "kind": {
          "$ref": "#/definitions/WorkflowRootKind"
        },
        "label": {
          "type": "string"
        },
        "path": {
          "type": "string"
        }
      },
      "required": [
        "kind",
        "label",
        "path"
      ],
      "type": "object"
    },
    "WorkflowRootKind": {
      "enum": [
        "global",
        "project",
        "searchPath"
      ],
      "type": "string"
    },
    "WorkflowSummary": {
      "properties": {
        "id": {
          "type": "string"
        },
        "mentionTarget": {
          "type": "string"
        },
        "path": {
          "type": "string"
        },
        "repairMode": {
          "type": "string"
        },
        "rootKind": {
          "$ref": "#/definitions/WorkflowRootKind"
        },
        "rootLabel": {
          "type": "string"
        },
        "rootPath": {
          "type": "string"
        },
        "searchTerms": {
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "title": {
          "type": [
            "string",
            "null"
          ]
        },
        "userDescription": {
          "type": [
            "string",
            "null"
          ]
        },
        "validation": {
          "$ref": "#/definitions/WorkflowValidationInfo"
        },
        "workflowYamlPath": {
          "type": "string"
        }
      },
      "required": [
        "id",
        "mentionTarget",
        "path",
        "repairMode",
        "rootKind",
        "rootLabel",
        "rootPath",
        "searchTerms",
        "validation",
        "workflowYamlPath"
      ],
      "type": "object"
    },
    "WorkflowValidationInfo": {
      "properties": {
        "messages": {
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "status": {
          "$ref": "#/definitions/WorkflowValidationStatus"
        }
      },
      "required": [
        "messages",
        "status"
      ],
      "type": "object"
    },
    "WorkflowValidationStatus": {
      "enum": [
        "valid",
        "invalid"
      ],
      "type": "string"
    }
  },
  "properties": {
    "config": {
      "$ref": "#/definitions/WorkflowConfigValues"
    },
    "roots": {
      "items": {
        "$ref": "#/definitions/WorkflowRootInfo"
      },
      "type": "array"
    },
    "workflows": {
      "items": {
        "$ref": "#/definitions/WorkflowSummary"
      },
      "type": "array"
    }
  },
  "required": [
    "config",
    "roots",
    "workflows"
  ],
  "title": "WorkflowAuthoringContextPrepareResponse",
  "type": "object"
}