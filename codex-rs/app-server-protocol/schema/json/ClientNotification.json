{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "definitions": {
    "WorkflowChildStatus": {
      "properties": {
        "threads": {
          "items": {
            "$ref": "#/definitions/WorkflowThreadStatus"
          },
          "type": "array"
        },
        "workflowName": {
          "type": "string"
        },
        "workflowStatus": {
          "type": "string"
        }
      },
      "required": [
        "threads",
        "workflowName",
        "workflowStatus"
      ],
      "type": "object"
    },
    "WorkflowMarkdownResultNotification": {
      "properties": {
        "markdown": {
          "type": "string"
        },
        "runId": {
          "type": "string"
        },
        "threadId": {
          "type": [
            "string",
            "null"
          ]
        }
      },
      "required": [
        "markdown",
        "runId"
      ],
      "type": "object"
    },
    "WorkflowProgressNotification": {
      "properties": {
        "data": true,
        "message": {
          "type": "string"
        },
        "runId": {
          "type": "string"
        },
        "status": {
          "anyOf": [
            {
              "$ref": "#/definitions/WorkflowStatusUpdate"
            },
            {
              "type": "null"
            }
          ]
        },
        "threadId": {
          "type": [
            "string",
            "null"
          ]
        }
      },
      "required": [
        "message",
        "runId"
      ],
      "type": "object"
    },
    "WorkflowStatusUpdate": {
      "properties": {
        "childStatuses": {
          "items": {
            "$ref": "#/definitions/WorkflowChildStatus"
          },
          "type": "array"
        },
        "threads": {
          "items": {
            "$ref": "#/definitions/WorkflowThreadStatus"
          },
          "type": "array"
        },
        "workflowName": {
          "type": "string"
        },
        "workflowStatus": {
          "type": "string"
        }
      },
      "required": [
        "childStatuses",
        "threads",
        "workflowName",
        "workflowStatus"
      ],
      "type": "object"
    },
    "WorkflowThreadStatus": {
      "properties": {
        "name": {
          "type": "string"
        },
        "status": {
          "type": "string"
        }
      },
      "required": [
        "name",
        "status"
      ],
      "type": "object"
    }
  },
  "oneOf": [
    {
      "properties": {
        "method": {
          "enum": [
            "initialized"
          ],
          "title": "InitializedNotificationMethod",
          "type": "string"
        }
      },
      "required": [
        "method"
      ],
      "title": "InitializedNotification",
      "type": "object"
    },
    {
      "properties": {
        "method": {
          "enum": [
            "workflowRun/progress"
          ],
          "title": "WorkflowRun/progressNotificationMethod",
          "type": "string"
        },
        "params": {
          "$ref": "#/definitions/WorkflowProgressNotification"
        }
      },
      "required": [
        "method",
        "params"
      ],
      "title": "WorkflowRun/progressNotification",
      "type": "object"
    },
    {
      "properties": {
        "method": {
          "enum": [
            "workflowRun/reportToUserMarkdown"
          ],
          "title": "WorkflowRun/reportToUserMarkdownNotificationMethod",
          "type": "string"
        },
        "params": {
          "$ref": "#/definitions/WorkflowMarkdownResultNotification"
        }
      },
      "required": [
        "method",
        "params"
      ],
      "title": "WorkflowRun/reportToUserMarkdownNotification",
      "type": "object"
    }
  ],
  "title": "ClientNotification"
}